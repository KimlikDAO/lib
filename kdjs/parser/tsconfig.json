{
	"compilerOptions": {
		"allowJs": true,
		"target": "esnext",
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "node",
		"outDir": "lib",
		"experimentalDecorators": true,
		"lib": ["es2017", "dom"],
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"preserveConstEnums": true,
		"removeComments": false,
		"sourceMap": true,
		"strict": false,
		"skipLibCheck": true
	},
	"include": ["./**/*"],
	"exclude": ["./test/*/input.ts"]
}
