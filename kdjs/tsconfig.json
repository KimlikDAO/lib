{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "preserveConstEnums": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["./**/*"],
  "exclude": [
    "**/node_modules",
    "**/build",
    "**/.kdjs_isolate",
    "parser/test/*/input.ts",
    "transformer/test/**"
  ]
}
