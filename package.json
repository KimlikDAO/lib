  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "mkdir -p ./node_modules/@kimlikdao/lib && ln -sfn ../../../kastro ./node_modules/@kimlikdao/lib/kastro && ln -sfn ../../../kdts ./node_modules/@kimlikdao/lib/kdts",
    "test": "bun util/testing/runner.js test",
    "bench": "bun util/testing/runner.js bench",
    "kdts": "bun kdts/kdts.js",
    "clear": "rm -rf build && clear"
  },
  "devDependencies": {
    "@ethereumjs/evm": "^10.1.1",
    "@noble/secp256k1": "^3.0.0",
    "@types/bun": "^1.3.11",
    "@types/sax": "^1.2.7",
    "@types/uglify-js": "^3.17.5",
    "ethers": "^6.16.0",
    "mina-signer": "^3.1.0"
  },
  "dependencies": {
    "@swc/core": "^1.15.21",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "astring": "^1.9.0",
    "css-tree": "^3.2.1",
    "csso": "^5.0.5",
    "google-closure-compiler": "^20260318.0.0",
    "html-minifier": "^4.0.0",
    "js-yaml": "^4.1.1",
    "sax": "^1.6.0",
    "svgo": "^4.0.1",
    "uglify-js": "~3.19.3"
  }
}
