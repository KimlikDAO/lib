{
  "name": "@kimlikdao/kdts",
  "description": "KimlikDAO TypeScript compiler",
  "author": "KimlikDAO <dao@kimlikdao.org>",
  "version": "0.0.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KimlikDAO/kimlikdao-lib.git",
    "directory": "kdts"
  },
  "homepage": "https://github.com/KimlikDAO/kimlikdao-lib/tree/ana/kdts",
  "bugs": {
    "url": "https://github.com/KimlikDAO/kimlikdao-lib/issues"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "types": "./kdts.d.ts",
  "scripts": {
    "build": "rm -rf ./build && mkdir -p ./build/util && cp ./package.json ./kdts.d.ts ./bench.ts ./build/ && cp ./util/assert.ts ./util/arrays.ts ./util/cli.ts ./build/util/ && bun kdts.ts kdts.ts --fast -o ./build/kdts.js",
    "release": "npm run build && npm publish ./build"
  },
  "dependencies": {
    "@swc/core": "^1.15.26",
    "acorn": "^8.16.0",
    "google-closure-compiler": "^20260415.0.0",
    "uglify-js": "3.19.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "bin": {
    "kdts": "kdts.js"
  },
  "kdts": {
    "sources": "."
  }
}
